# PinayMate — client environment variables
# Copy this file to `.env` and fill in your Supabase project's values.
#
# ⚠️ Anything prefixed EXPO_PUBLIC_* is bundled into the client app.
#    Use ONLY the public "anon" key here — never the service-role secret.

# Supabase project — Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<your-anon-public-key>

# Optional (testers only): skip the auth gate and land directly in /(main).
# Leave UNSET in production.
# EXPO_PUBLIC_BYPASS_AUTH=true
