EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Optional. Leave blank to derive https://<project-ref>.functions.supabase.co/ocr.
# If set to a custom backend, it must validate the Authorization: Bearer <Supabase access token> header.
EXPO_PUBLIC_OCR_ENDPOINT=
