# Supabase Configuration
# Replace these values with your actual Supabase project URL and anon key
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional OCR configuration
# EXPO_PUBLIC_OCR_ENDPOINT=https://your-project-ref.functions.supabase.co/ocr
# Ensure custom OCR endpoints validate: Authorization: Bearer <Supabase access token>

# Optional local-only OCR live proof account.
# Use an existing disposable beta user; never commit real values.
# OCR_PROOF_EMAIL=release-proof@example.com
# OCR_PROOF_PASSWORD=replace-with-local-only-password
# OCR_PROOF_VALID_DOC_PATH=C:\path\to\synthetic-valid-document.png
# OCR_PROOF_INVALID_DOC_PATH=C:\path\to\synthetic-invalid-document.png
