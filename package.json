{
  "name": "pinaymate",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export -p web && node scripts/patch-web-export.js",
    "check:local-quality": "npm run check:source-contracts && npm run check:dependency-audit && npm run lint && npx tsc --noEmit --pretty false && npm test -- --runInBand --no-cache && npm run build:web",
    "check:safety-operations-contract": "node scripts/check-safety-operations-contract.mjs",
    "check:source-contracts": "npm run check:secret-hygiene && npm run check:privacy-logs && npm run check:supabase-static-contract && npm run check:migration-manifest && npm run check:user-facing-safe-errors && npm run check:auth-redirect-contract && npm run check:env-template-contract && npm run check:product-design-contract && npm run check:client-copy && npm run check:notification-delivery-contract && npm run check:vercel-branch-policy && npm run check:launch-file-contract",
    "check:privacy-logs": "node scripts/check-privacy-logs.mjs",
    "check:release-local": "node scripts/check-release-local.mjs",
    "check:dependency-audit": "npm audit --audit-level=moderate",
    "check:user-facing-safe-errors": "node scripts/check-user-facing-safe-errors.mjs",
    "check:auth-redirect-contract": "node scripts/check-auth-redirect-contract.mjs",
    "check:env-template-contract": "node scripts/check-env-template-contract.mjs",
    "check:production-ownership-contract": "node scripts/check-production-ownership-contract.mjs",
    "check:product-design-contract": "node scripts/check-product-design-contract.mjs",
    "check:notification-delivery-contract": "node scripts/check-notification-delivery-contract.mjs",
    "check:vercel-branch-policy": "node scripts/check-vercel-branch-policy.mjs",
    "check:launch-evidence-contract": "node scripts/check-launch-evidence-contract.mjs",
    "check:launch-file-contract": "node scripts/check-launch-file-contract.mjs",
    "check:secret-hygiene": "node scripts/check-secret-hygiene.mjs",
    "check:migration-manifest": "node scripts/check-supabase-migration-manifest.mjs",
    "check:supabase-static-contract": "node scripts/check-supabase-static-contract.mjs",
    "check:supabase-static-contract:report": "node scripts/check-supabase-static-contract.mjs --write-report",
    "proof:ocr:live": "node scripts/proof-ocr-live.mjs",
    "proof:photo-upload:live": "node scripts/proof-photo-upload-live.mjs",
    "lint": "expo lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "check:client-copy": "node scripts/check-client-facing-copy.mjs",
    "smoke:beta-preview": "playwright test \"scripts/smoke-beta-preview.spec.js\" --reporter=line",
    "smoke:web-mvp": "playwright test \"scripts/smoke-web-mvp.spec.js\" --reporter=line",
    "analyze:web": "set EXPO_UNSTABLE_ATLAS=true&& expo export -p web",
    "analyze:atlas": "npx expo-atlas"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@ptomasroos/react-native-multi-slider": "^2.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.76.1",
    "base64-arraybuffer": "^1.0.2",
    "expo": "~54.0.7",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.8",
    "expo-font": "~14.0.9",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.8",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.4",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.11",
    "expo-web-browser": "~15.0.11",
    "lucide-react-native": "^0.562.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "zod": "^4.3.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "babel-plugin-import": "^1.13.8",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "expo-atlas": "^0.4.3",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.13",
    "sharp": "^0.35.2",
    "typescript": "~5.9.2"
  },
  "private": true,
  "overrides": {
    "brace-expansion": "1.1.13",
    "postcss": "8.5.10",
    "uuid": "11.1.1",
    "js-yaml": "^4.1.2"
  }
}
